@page "/periodos"
@attribute [Authorize]
@inject IApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>EduCore - Periodos Academicos</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;"><MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />Periodos Academicos</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Nuevo Periodo</MudButton>
</MudStack>

<MudPaper Elevation="2" Class="fade-in">
    <MudTable Items="@_items" Hover="true" Striped="true" Loading="@_loading" Dense="true" Elevation="0">
        <HeaderContent>
            <MudTh>Nombre</MudTh><MudTh>Ano</MudTh><MudTh>Inicio</MudTh><MudTh>Fin</MudTh><MudTh>Actual</MudTh><MudTh>Estado</MudTh><MudTh Style="text-align:center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd><MudTd>@context.Year</MudTd>
            <MudTd>@context.StartDate.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@context.EndDate.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@(context.IsCurrent ? "Si" : "No")</MudTd>
            <MudTd><MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">@(context.IsActive ? "Activo" : "Inactivo")</MudChip></MudTd>
            <MudTd Style="text-align:center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Del(context))" />
            </MudTd>
        </RowTemplate>
        <PagerContent><MudTablePager PageSizeOptions="new[]{10,25}" /></PagerContent>
    </MudTable>
</MudPaper>

<MudDialog @bind-Visible="_dlg" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">@(_edit ? "Editar" : "Nuevo") Periodo</MudText></TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_m.Name" Label="Nombre" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="6"><MudNumericField @bind-Value="_m.Year" Label="Ano" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_startDate" Label="Fecha Inicio" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="6"><MudDatePicker @bind-Date="_endDate" Label="Fecha Fin" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12"><MudCheckBox @bind-Value="_m.IsCurrent" Label="Periodo Actual" Color="Color.Primary" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dlg = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<AcademicPeriodDto> _items = new();
    private AcademicPeriodDto _m = new();
    private bool _loading = true, _dlg, _edit;
    private DateTime? _startDate, _endDate;

    protected override async Task OnInitializedAsync() { _items = await ApiService.GetListAsync<AcademicPeriodDto>("academicperiods"); _loading = false; }
    private void OpenCreate() { _m = new AcademicPeriodDto { IsActive = true, Year = DateTime.Now.Year }; _startDate = DateTime.Now; _endDate = DateTime.Now.AddMonths(6); _edit = false; _dlg = true; }
    private void OpenEdit(AcademicPeriodDto p) { _m = new AcademicPeriodDto { Id = p.Id, Name = p.Name, Year = p.Year, StartDate = p.StartDate, EndDate = p.EndDate, IsCurrent = p.IsCurrent, IsActive = p.IsActive }; _startDate = p.StartDate; _endDate = p.EndDate; _edit = true; _dlg = true; }
    private async Task Save() { if (_startDate.HasValue) _m.StartDate = _startDate.Value; if (_endDate.HasValue) _m.EndDate = _endDate.Value; if (_edit) await ApiService.PutAsync($"academicperiods/{_m.Id}", _m); else await ApiService.PostAsync<AcademicPeriodDto>("academicperiods", _m); Snackbar.Add("Guardado", Severity.Success); _dlg = false; _items = await ApiService.GetListAsync<AcademicPeriodDto>("academicperiods"); }
    private async Task Del(AcademicPeriodDto p) { if (await DialogService.ShowMessageBoxAsync("Confirmar", $"Eliminar {p.Name}?", yesText: "Si", cancelText: "No") == true) { await ApiService.DeleteAsync($"academicperiods/{p.Id}"); _items = await ApiService.GetListAsync<AcademicPeriodDto>("academicperiods"); } }
}