        _showSectionDialog = true;
    }

    private async Task SaveSection()
    {
        _saving = true;
        try
        {
            if (_editingSection.Id == 0)
                await ApiService.PostAsync<InstituteSectionDto>("configuration/sections", _editingSection);
            else
                await ApiService.PutAsync($"configuration/sections/{_editingSection.Id}", _editingSection);

            Snackbar.Add("Seccion guardada correctamente", Severity.Success);
            _showSectionDialog = false;
            await LoadSections();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
