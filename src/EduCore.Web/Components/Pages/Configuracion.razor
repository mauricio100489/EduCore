    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="int" @bind-Value="_editingSection.InstituteId" Label="Instituto" Variant="Variant.Outlined" Required="true"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="int" @bind-Value="_editingSection.PeriodId" Label="Periodo" Variant="Variant.Outlined" Required="true"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in _periods.Where(p => p.InstituteId == _editingSection.InstituteId))
                    {
                        <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_editingSection.SectionName" Label="Nombre Seccion" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_editingSection.Order" Label="Orden" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showSectionDialog = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSection" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // Tab
    private int _activeTab = 0;
    private bool _saving = false;

    // === DATA ===
    private List<InstituteDto> _institutes = new();
    private List<InstitutePeriodDto> _periods = new();
    private List<InstituteGradeDto> _grades = new();
    private List<InstituteShiftDto> _shifts = new();
    private List<InstituteSectionDto> _sections = new();

    // === LOADING ===
    private bool _loadingInstitutes, _loadingPeriods, _loadingGrades, _loadingShifts, _loadingSections;

    // === FILTERS ===
    private int _selectedInstituteForPeriods;
    private int _selectedInstituteForGrades, _selectedPeriodForGrades;
    private int _selectedInstituteForShifts, _selectedPeriodForShifts;
    private int _selectedInstituteForSections, _selectedPeriodForSections;

    // === EDITING MODELS ===
    private InstituteDto _editingInstitute = new();
    private InstitutePeriodDto _editingPeriod = new();
    private InstituteGradeDto _editingGrade = new();
    private InstituteShiftDto _editingShift = new();
    private InstituteSectionDto _editingSection = new();

    // === DIALOGS ===
    private bool _showInstituteDialog, _showPeriodDialog, _showGradeDialog, _showShiftDialog, _showSectionDialog;

    // Date pickers
    private DateTime? _periodStartDate, _periodEndDate;

    // Filtered periods
    private IEnumerable<InstitutePeriodDto> _filteredPeriods =>
        _selectedInstituteForPeriods == 0 ? _periods : _periods.Where(p => p.InstituteId == _selectedInstituteForPeriods);

    protected override async Task OnInitializedAsync()
    {
        await LoadInstitutes();
        await LoadPeriods();
    }

    // ===== INSTITUTES CRUD =====
    private async Task LoadInstitutes()
    {
        _loadingInstitutes = true;
        try { _institutes = await ApiService.GetListAsync<InstituteDto>("configuration/institutes"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loadingInstitutes = false; }
    }

    private void OpenCreateInstitute() { _editingInstitute = new(); _showInstituteDialog = true; }

    private void OpenEditInstitute(InstituteDto inst)
    {
        _editingInstitute = new InstituteDto
        {
            Id = inst.Id, Code = inst.Code, Rtn = inst.Rtn, Name = inst.Name,
            Slogan = inst.Slogan, Address = inst.Address, Phones = inst.Phones,
            Director = inst.Director, Secretary = inst.Secretary, IsActive = inst.IsActive
        };
        _showInstituteDialog = true;
    }

    private async Task SaveInstitute()
    {
        _saving = true;
        try
        {
            if (_editingInstitute.Id == 0)
                await ApiService.PostAsync<InstituteDto>("configuration/institutes", _editingInstitute);
            else
                await ApiService.PutAsync($"configuration/institutes/{_editingInstitute.Id}", _editingInstitute);

            Snackbar.Add("Instituto guardado correctamente", Severity.Success);
            _showInstituteDialog = false;
            await LoadInstitutes();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeleteInstitute(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync("Confirmar", "Desea eliminar este instituto?", yesText: "Si", cancelText: "No");
        if (result == true)
        {
            try
            {
                await ApiService.DeleteAsync($"configuration/institutes/{id}");
                Snackbar.Add("Instituto eliminado", Severity.Info);
                await LoadInstitutes();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ===== PERIODS CRUD =====
    private async Task LoadPeriods()
    {
        _loadingPeriods = true;
        try { _periods = await ApiService.GetListAsync<InstitutePeriodDto>("configuration/periods"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loadingPeriods = false; }
    }

    private void OpenCreatePeriod()
    {
        _editingPeriod = new InstitutePeriodDto
        {
            InstituteId = _selectedInstituteForPeriods > 0 ? _selectedInstituteForPeriods : (_institutes.FirstOrDefault()?.Id ?? 0)
        };
        _periodStartDate = null;
        _periodEndDate = null;
        _showPeriodDialog = true;
    }

    private void OpenEditPeriod(InstitutePeriodDto p)
    {
        _editingPeriod = new InstitutePeriodDto
        {
            Id = p.Id, PeriodName = p.PeriodName, InstituteId = p.InstituteId,
            PromotionName = p.PromotionName, IsCurrent = p.IsCurrent, IsActive = p.IsActive
        };
        _periodStartDate = p.StartDate;
        _periodEndDate = p.EndDate;
        _showPeriodDialog = true;
    }

    private async Task SavePeriod()
    {
        _saving = true;
        _editingPeriod.StartDate = _periodStartDate;
        _editingPeriod.EndDate = _periodEndDate;
        try
        {
            if (_editingPeriod.Id == 0)
                await ApiService.PostAsync<InstitutePeriodDto>("configuration/periods", _editingPeriod);
            else
                await ApiService.PutAsync($"configuration/periods/{_editingPeriod.Id}", _editingPeriod);

            Snackbar.Add("Periodo guardado correctamente", Severity.Success);
            _showPeriodDialog = false;
            await LoadPeriods();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeletePeriod(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync("Confirmar", "Desea eliminar este periodo?", yesText: "Si", cancelText: "No");
        if (result == true)
        {
            try
            {
                await ApiService.DeleteAsync($"configuration/periods/{id}");
                Snackbar.Add("Periodo eliminado", Severity.Info);
                await LoadPeriods();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ===== GRADES CRUD =====
    private async Task LoadGrades()
    {
        if (_selectedInstituteForGrades == 0 || _selectedPeriodForGrades == 0) return;
        _loadingGrades = true;
        try { _grades = await ApiService.GetListAsync<InstituteGradeDto>($"configuration/grades/by-institute-period/{_selectedInstituteForGrades}/{_selectedPeriodForGrades}"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loadingGrades = false; }
    }

    private void OpenCreateGrade()
    {
        _editingGrade = new InstituteGradeDto
        {
            InstituteId = _selectedInstituteForGrades > 0 ? _selectedInstituteForGrades : (_institutes.FirstOrDefault()?.Id ?? 0),
            PeriodId = _selectedPeriodForGrades
        };
        _showGradeDialog = true;
    }

    private void OpenEditGrade(InstituteGradeDto g)
    {
        _editingGrade = new InstituteGradeDto
        {
            Id = g.Id, InstituteId = g.InstituteId, PeriodId = g.PeriodId, GradeName = g.GradeName,
            OfficialGrade = g.OfficialGrade, OfficialModality = g.OfficialModality, Order = g.Order,
            EnrollmentFee = g.EnrollmentFee, MonthlyFee12 = g.MonthlyFee12, MonthlyFee10 = g.MonthlyFee10,
            MaterialsFee = g.MaterialsFee, OtherFees = g.OtherFees, EvaluationType = g.EvaluationType,
            EmailSender = g.EmailSender, EmailName = g.EmailName, SmtpServer = g.SmtpServer,
            SmtpPort = g.SmtpPort, EmailTitle = g.EmailTitle, CounselorName = g.CounselorName,
            EducationLevelId = g.EducationLevelId, IsActive = g.IsActive
        };
        _showGradeDialog = true;
    }

    private async Task SaveGrade()
    {
        _saving = true;
        try
        {
            if (_editingGrade.Id == 0)
                await ApiService.PostAsync<InstituteGradeDto>("configuration/grades", _editingGrade);
            else
                await ApiService.PutAsync($"configuration/grades/{_editingGrade.Id}", _editingGrade);

            Snackbar.Add("Grado guardado correctamente", Severity.Success);
            _showGradeDialog = false;
            await LoadGrades();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeleteGrade(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync("Confirmar", "Desea eliminar este grado?", yesText: "Si", cancelText: "No");
        if (result == true)
        {
            try
            {
                await ApiService.DeleteAsync($"configuration/grades/{id}");
                Snackbar.Add("Grado eliminado", Severity.Info);
                await LoadGrades();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ===== SHIFTS CRUD =====
    private async Task LoadShifts()
    {
        if (_selectedInstituteForShifts == 0 || _selectedPeriodForShifts == 0) return;
        _loadingShifts = true;
        try { _shifts = await ApiService.GetListAsync<InstituteShiftDto>($"configuration/shifts/by-institute-period/{_selectedInstituteForShifts}/{_selectedPeriodForShifts}"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loadingShifts = false; }
    }

    private void OpenCreateShift()
    {
        _editingShift = new InstituteShiftDto
        {
            InstituteId = _selectedInstituteForShifts > 0 ? _selectedInstituteForShifts : (_institutes.FirstOrDefault()?.Id ?? 0),
            PeriodId = _selectedPeriodForShifts
        };
        _showShiftDialog = true;
    }

    private void OpenEditShift(InstituteShiftDto s)
    {
        _editingShift = new InstituteShiftDto
        {
            Id = s.Id, ShiftName = s.ShiftName, InstituteId = s.InstituteId,
            PeriodId = s.PeriodId, Order = s.Order, IsActive = s.IsActive
        };
        _showShiftDialog = true;
    }

    private async Task SaveShift()
    {
        _saving = true;
        try
        {
            if (_editingShift.Id == 0)
                await ApiService.PostAsync<InstituteShiftDto>("configuration/shifts", _editingShift);
            else
                await ApiService.PutAsync($"configuration/shifts/{_editingShift.Id}", _editingShift);

            Snackbar.Add("Jornada guardada correctamente", Severity.Success);
            _showShiftDialog = false;
            await LoadShifts();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeleteShift(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync("Confirmar", "Desea eliminar esta jornada?", yesText: "Si", cancelText: "No");
        if (result == true)
        {
            try
            {
                await ApiService.DeleteAsync($"configuration/shifts/{id}");
                Snackbar.Add("Jornada eliminada", Severity.Info);
                await LoadShifts();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    // ===== SECTIONS CRUD =====
    private async Task LoadSections()
    {
        if (_selectedInstituteForSections == 0 || _selectedPeriodForSections == 0) return;
        _loadingSections = true;
        try { _sections = await ApiService.GetListAsync<InstituteSectionDto>($"configuration/sections/by-institute-period/{_selectedInstituteForSections}/{_selectedPeriodForSections}"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loadingSections = false; }
    }

    private void OpenCreateSection()
    {
        _editingSection = new InstituteSectionDto
        {
            InstituteId = _selectedInstituteForSections > 0 ? _selectedInstituteForSections : (_institutes.FirstOrDefault()?.Id ?? 0),
            PeriodId = _selectedPeriodForSections
        };
        _showSectionDialog = true;
    }

    private void OpenEditSection(InstituteSectionDto s)
    {
        _editingSection = new InstituteSectionDto
        {
            Id = s.Id, SectionName = s.SectionName, InstituteId = s.InstituteId,
            PeriodId = s.PeriodId, Order = s.Order, IsActive = s.IsActive
