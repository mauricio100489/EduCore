@page "/configuracion"
@attribute [Authorize]
@inject IApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>EduCore - Configuracion</PageTitle>

<MudText Typo="Typo.h4" Style="font-weight: 700;" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
    Configuracion del Sistema
</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4"
         @bind-ActivePanelIndex="_activeTab">
    <MudTabPanel Text="Institutos" Icon="@Icons.Material.Filled.Business">
        @* ===== INSTITUTOS TAB ===== *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Institutos Registrados</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateInstitute" Size="Size.Small">Nuevo Instituto</MudButton>
        </MudStack>
        <MudTable Items="@_institutes" Hover="true" Striped="true" Loading="@_loadingInstitutes" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Codigo</MudTh>
                <MudTh>Nombre</MudTh>
                <MudTh>RTN</MudTh>
                <MudTh>Director</MudTh>
                <MudTh>Telefonos</MudTh>
                <MudTh Style="text-align:center;">Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Code</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Rtn</MudTd>
                <MudTd>@context.Director</MudTd>
                <MudTd>@context.Phones</MudTd>
                <MudTd Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditInstitute(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteInstitute(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent><MudText>No hay institutos registrados</MudText></NoRecordsContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Periodos" Icon="@Icons.Material.Filled.CalendarMonth">
        @* ===== PERIODOS TAB ===== *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Periodos Academicos</MudText>
                <MudSelect T="int" Label="Instituto" @bind-Value="_selectedInstituteForPeriods" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:250px;" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="int" Value="0">-- Todos --</MudSelectItem>
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadPeriods" Color="Color.Primary" />
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreatePeriod" Size="Size.Small">Nuevo Periodo</MudButton>
        </MudStack>
        <MudTable Items="@_filteredPeriods" Hover="true" Striped="true" Loading="@_loadingPeriods" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Periodo</MudTh>
                <MudTh>Instituto</MudTh>
                <MudTh>Fecha Inicio</MudTh>
                <MudTh>Fecha Fin</MudTh>
                <MudTh>Promocion</MudTh>
                <MudTh>Actual</MudTh>
                <MudTh Style="text-align:center;">Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.PeriodName</MudTd>
                <MudTd>@context.InstituteName</MudTd>
                <MudTd>@context.StartDate?.ToString("dd/MM/yyyy")</MudTd>
                <MudTd>@context.EndDate?.ToString("dd/MM/yyyy")</MudTd>
                <MudTd>@context.PromotionName</MudTd>
                <MudTd>
                    @if (context.IsCurrent)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Si</MudChip>
                    }
                </MudTd>
                <MudTd Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditPeriod(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeletePeriod(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent><MudText>No hay periodos registrados</MudText></NoRecordsContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Grados" Icon="@Icons.Material.Filled.Layers">
        @* ===== GRADOS TAB ===== *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Grados</MudText>
                <MudSelect T="int" Label="Instituto" @bind-Value="_selectedInstituteForGrades" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" Label="Periodo" @bind-Value="_selectedPeriodForGrades" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in _periods.Where(p => p.InstituteId == _selectedInstituteForGrades))
                    {
                        <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                    }
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadGrades" Color="Color.Primary" />
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateGrade" Size="Size.Small">Nuevo Grado</MudButton>
        </MudStack>
        <MudTable Items="@_grades" Hover="true" Striped="true" Loading="@_loadingGrades" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Orden</MudTh>
                <MudTh>Grado</MudTh>
                <MudTh>Grado Oficial</MudTh>
                <MudTh>Modalidad</MudTh>
                <MudTh>Matricula</MudTh>
                <MudTh>Mensualidad 12</MudTh>
                <MudTh>Mensualidad 10</MudTh>
                <MudTh Style="text-align:center;">Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Order</MudTd>
                <MudTd>@context.GradeName</MudTd>
                <MudTd>@context.OfficialGrade</MudTd>
                <MudTd>@context.OfficialModality</MudTd>
                <MudTd>@context.EnrollmentFee?.ToString("C")</MudTd>
                <MudTd>@context.MonthlyFee12?.ToString("C")</MudTd>
                <MudTd>@context.MonthlyFee10?.ToString("C")</MudTd>
                <MudTd Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditGrade(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteGrade(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent><MudText>No hay grados registrados para este instituto/periodo</MudText></NoRecordsContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Jornadas" Icon="@Icons.Material.Filled.Schedule">
        @* ===== JORNADAS TAB ===== *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Jornadas</MudText>
                <MudSelect T="int" Label="Instituto" @bind-Value="_selectedInstituteForShifts" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" Label="Periodo" @bind-Value="_selectedPeriodForShifts" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in _periods.Where(p => p.InstituteId == _selectedInstituteForShifts))
                    {
                        <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                    }
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadShifts" Color="Color.Primary" />
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateShift" Size="Size.Small">Nueva Jornada</MudButton>
        </MudStack>
        <MudTable Items="@_shifts" Hover="true" Striped="true" Loading="@_loadingShifts" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Orden</MudTh>
                <MudTh>Jornada</MudTh>
                <MudTh>Instituto</MudTh>
                <MudTh>Periodo</MudTh>
                <MudTh Style="text-align:center;">Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Order</MudTd>
                <MudTd>@context.ShiftName</MudTd>
                <MudTd>@context.InstituteName</MudTd>
                <MudTd>@context.PeriodName</MudTd>
                <MudTd Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditShift(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteShift(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent><MudText>No hay jornadas registradas</MudText></NoRecordsContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Secciones" Icon="@Icons.Material.Filled.ViewModule">
        @* ===== SECCIONES TAB ===== *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Secciones</MudText>
                <MudSelect T="int" Label="Instituto" @bind-Value="_selectedInstituteForSections" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" Label="Periodo" @bind-Value="_selectedPeriodForSections" Variant="Variant.Outlined"
                           Dense="true" Style="min-width:200px;" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in _periods.Where(p => p.InstituteId == _selectedInstituteForSections))
                    {
                        <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                    }
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadSections" Color="Color.Primary" />
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateSection" Size="Size.Small">Nueva Seccion</MudButton>
        </MudStack>
        <MudTable Items="@_sections" Hover="true" Striped="true" Loading="@_loadingSections" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>Orden</MudTh>
                <MudTh>Seccion</MudTh>
                <MudTh>Instituto</MudTh>
                <MudTh>Periodo</MudTh>
                <MudTh Style="text-align:center;">Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Order</MudTd>
                <MudTd>@context.SectionName</MudTd>
                <MudTd>@context.InstituteName</MudTd>
                <MudTd>@context.PeriodName</MudTd>
                <MudTd Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditSection(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteSection(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent><MudText>No hay secciones registradas</MudText></NoRecordsContent>
        </MudTable>
    </MudTabPanel>
</MudTabs>

@* ===== DIALOG: INSTITUTO ===== *@
<MudDialog @bind-Visible="_showInstituteDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
            @(_editingInstitute.Id == 0 ? "Nuevo Instituto" : "Editar Instituto")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_editingInstitute.Code" Label="Codigo" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_editingInstitute.Name" Label="Nombre" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingInstitute.Rtn" Label="RTN" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingInstitute.Phones" Label="Telefonos" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_editingInstitute.Address" Label="Direccion" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingInstitute.Slogan" Label="Eslogan" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingInstitute.Director" Label="Director" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingInstitute.Secretary" Label="Secretario(a)" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showInstituteDialog = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveInstitute" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@* ===== DIALOG: PERIODO ===== *@
<MudDialog @bind-Visible="_showPeriodDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
            @(_editingPeriod.Id == 0 ? "Nuevo Periodo" : "Editar Periodo")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="int" @bind-Value="_editingPeriod.InstituteId" Label="Instituto" Variant="Variant.Outlined" Required="true"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingPeriod.PeriodName" Label="Periodo (ej: 2025-2026)" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_editingPeriod.PromotionName" Label="Nombre Promocion" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_periodStartDate" Label="Fecha Inicio" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_periodEndDate" Label="Fecha Fin" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12">
                <MudCheckBox @bind-Value="_editingPeriod.IsCurrent" Label="Es el periodo actual" Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPeriodDialog = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePeriod" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@* ===== DIALOG: GRADO ===== *@
<MudDialog @bind-Visible="_showGradeDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Layers" Class="mr-2" />
            @(_editingGrade.Id == 0 ? "Nuevo Grado" : "Editar Grado")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
            <MudTabPanel Text="Datos Generales" Icon="@Icons.Material.Filled.Info">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int" @bind-Value="_editingGrade.InstituteId" Label="Instituto" Variant="Variant.Outlined" Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var inst in _institutes)
                            {
                                <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int" @bind-Value="_editingGrade.PeriodId" Label="Periodo" Variant="Variant.Outlined" Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var p in _periods.Where(p => p.InstituteId == _editingGrade.InstituteId))
                            {
                                <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.GradeName" Label="Grado Instituto" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.OfficialGrade" Label="Grado Oficial" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.OfficialModality" Label="Modalidad Oficial" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudNumericField @bind-Value="_editingGrade.Order" Label="Orden" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="_editingGrade.EvaluationType" Label="Tipo Evaluacion" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Tarifas" Icon="@Icons.Material.Filled.AttachMoney">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudNumericField @bind-Value="_editingGrade.EnrollmentFee" Label="Matricula" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentText="L" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField @bind-Value="_editingGrade.MonthlyFee12" Label="Mensualidad (12 meses)" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentText="L" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField @bind-Value="_editingGrade.MonthlyFee10" Label="Mensualidad (10 meses)" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentText="L" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_editingGrade.MaterialsFee" Label="Materiales/Libros" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentText="L" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_editingGrade.OtherFees" Label="Otros" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentText="L" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Correo" Icon="@Icons.Material.Filled.Email">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.EmailSender" Label="Correo Remitente" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.EmailName" Label="Nombre Correo" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.SmtpServer" Label="Servidor SMTP" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudNumericField @bind-Value="_editingGrade.SmtpPort" Label="Puerto SMTP" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="_editingGrade.EmailTitle" Label="Titulo Correo" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Orientador" Icon="@Icons.Material.Filled.Person">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editingGrade.CounselorName" Label="Nombre Orientador" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_editingGrade.EducationLevelId" Label="ID Nivel Educativo" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showGradeDialog = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveGrade" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@* ===== DIALOG: JORNADA ===== *@
<MudDialog @bind-Visible="_showShiftDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" />
            @(_editingShift.Id == 0 ? "Nueva Jornada" : "Editar Jornada")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="int" @bind-Value="_editingShift.InstituteId" Label="Instituto" Variant="Variant.Outlined" Required="true"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var inst in _institutes)
                    {
                        <MudSelectItem T="int" Value="@inst.Id">@inst.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="int" @bind-Value="_editingShift.PeriodId" Label="Periodo" Variant="Variant.Outlined" Required="true"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var p in _periods.Where(p => p.InstituteId == _editingShift.InstituteId))
                    {
                        <MudSelectItem T="int" Value="@p.Id">@p.PeriodName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_editingShift.ShiftName" Label="Nombre Jornada" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_editingShift.Order" Label="Orden" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showShiftDialog = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveShift" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@* ===== DIALOG: SECCION ===== *@
<MudDialog @bind-Visible="_showSectionDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ViewModule" Class="mr-2" />
