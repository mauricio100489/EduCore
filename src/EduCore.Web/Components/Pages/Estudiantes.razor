@page "/estudiantes"
@attribute [Authorize]
@inject IApiService ApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using EduCore.Domain.Enums

<PageTitle>EduCore - Estudiantes</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
        Estudiantes
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenCreateDialog">
        Nuevo Estudiante
    </MudButton>
</MudStack>

<MudPaper Elevation="2" Class="fade-in">
    <MudStack Row="true" Class="pa-4" Spacing="3">
        <MudTextField @bind-Value="_searchTerm" Placeholder="Buscar estudiante..."
                      Variant="Variant.Outlined" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                      DebounceInterval="300" OnDebounceIntervalElapsed="SearchStudents"
                      Style="max-width: 400px;" />
    </MudStack>

    <MudTable Items="@_students" Hover="true" Striped="true" Loading="@_loading"
              LoadingProgressColor="Color.Primary" Dense="true" Elevation="0">
        <HeaderContent>
            <MudTh>#Cuenta</MudTh>
            <MudTh>Nombre Completo</MudTh>
            <MudTh>Identidad</MudTh>
            <MudTh>Genero</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh Style="text-align: center;">Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#Cuenta">@context.AccountNumber</MudTd>
            <MudTd DataLabel="Nombre">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">
                        @context.FirstName[0]@context.LastName[0]
                    </MudAvatar>
                    @context.FullName
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Identidad">@context.IdentificationNumber</MudTd>
            <MudTd DataLabel="Genero">@context.Gender</MudTd>
            <MudTd DataLabel="Estado">
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsActive ? "Activo" : "Inactivo")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Acciones" Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" Title="Editar" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteStudent(context))" Title="Eliminar" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Align="Align.Center" Class="pa-4">No se encontraron estudiantes</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

<MudDialog @bind-Visible="_dialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_isEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.PersonAdd)" Class="mr-2" />
            @(_isEdit ? "Editar Estudiante" : "Nuevo Estudiante")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            @* Tab 1: Datos Personales *@
            <MudTabPanel Text="Datos Personales" Icon="@Icons.Material.Filled.Person">
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editingStudent.FirstName" Label="Nombres" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editingStudent.LastName" Label="Apellidos" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editingStudent.AccountNumber" Label="Numero de Cuenta" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editingStudent.IdentificationNumber" Label="No. Identificacion" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_editingStudent.Gender" Label="Genero" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Masculino")">Masculino</MudSelectItem>
                            <MudSelectItem Value="@("Femenino")">Femenino</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="_birthDate" Label="Fecha de Nacimiento" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_editingStudent.BirthPlace" Label="Lugar de Nacimiento" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_editingStudent.Handedness" Label="Mano Dominante" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Derecha")">Derecha</MudSelectItem>
                            <MudSelectItem Value="@("Izquierda")">Izquierda</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_editingStudent.Address" Label="Direccion" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            @* Tab 2: Salud *@
            <MudTabPanel Text="Salud" Icon="@Icons.Material.Filled.LocalHospital">
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_editingStudent.MedicalConditions" Label="Condiciones Medicas" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox @bind-Value="_editingStudent.HasAllergies" Label="Tiene Alergias" Color="Color.Primary" />
                    </MudItem>
                    @if (_editingStudent.HasAllergies == true)
                    {
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_editingStudent.AllergiesDescription" Label="Descripcion de Alergias" Variant="Variant.Outlined" Lines="3" />
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>

            @* Tab 3: Familia *@
            <MudTabPanel Text="Familia" Icon="@Icons.Material.Filled.FamilyRestroom">
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="4">
                        <MudSelect @bind-Value="_editingStudent.HasSiblings" Label="Tiene Hermanos" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Si")">Si</MudSelectItem>
                            <MudSelectItem Value="@("No")">No</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    @if (_editingStudent.HasSiblings == "Si")
                    {
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_editingStudent.SiblingsCount" Label="Cantidad de Hermanos" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_editingStudent.SiblingsGrades" Label="Grados de Hermanos" Variant="Variant.Outlined" Lines="2" />
                        </MudItem>
                    }

                    @* Madre *@
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Woman" Class="mr-1" Size="Size.Small" />
                            Madre
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Mother).IdentificationNumber" Label="Identidad" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Mother).FullName" Label="Nombre Completo" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Mother).Phones" Label="Telefonos" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Mother).Email" Label="Email" Variant="Variant.Outlined" />
                    </MudItem>

                    @* Padre *@
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Man" Class="mr-1" Size="Size.Small" />
                            Padre
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Father).IdentificationNumber" Label="Identidad" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Father).FullName" Label="Nombre Completo" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Father).Phones" Label="Telefonos" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Father).Email" Label="Email" Variant="Variant.Outlined" />
                    </MudItem>

                    @* Encargado *@
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.SupervisedUserCircle" Class="mr-1" Size="Size.Small" />
                            Encargado
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Guardian).IdentificationNumber" Label="Identidad" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Guardian).FullName" Label="Nombre Completo" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Guardian).Phones" Label="Telefonos" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="GetGuardian(GuardianType.Guardian).Email" Label="Email" Variant="Variant.Outlined" />
                    </MudItem>

                    @* Observaciones *@
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudTextField @bind-Value="_editingStudent.ParentObservations" Label="Observaciones de los Padres" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            @* Tab 4: Otros *@
            <MudTabPanel Text="Otros" Icon="@Icons.Material.Filled.MoreHoriz">
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_editingStudent.ReferralEmails" Label="Emails de Referencia" Variant="Variant.Outlined" Lines="3"
                                      HelperText="Ingrese los correos electronicos separados por coma" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogVisible = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveStudent" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<StudentDto> _students = new();
    private StudentDto _editingStudent = new();
    private bool _loading = true, _dialogVisible, _isEdit, _saving;
    private string _searchTerm = string.Empty;
    private DateTime? _birthDate;

    protected override async Task OnInitializedAsync() => await LoadStudents();

    private async Task LoadStudents()
    {
        _loading = true;
        try { _students = await ApiService.GetListAsync<StudentDto>("students"); }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SearchStudents(string term)
    {
        if (string.IsNullOrWhiteSpace(term)) { await LoadStudents(); return; }
        _loading = true;
        try { _students = await ApiService.GetListAsync<StudentDto>($"students/search/{term}"); }
        catch { await LoadStudents(); }
        finally { _loading = false; }
    }

    private void OpenCreateDialog()
    {
        _editingStudent = new StudentDto
        {
            IsActive = true,
            Guardians = new List<StudentGuardianDto>
            {
                new() { Type = GuardianType.Mother },
                new() { Type = GuardianType.Father },
                new() { Type = GuardianType.Guardian }
            }
        };
        _birthDate = null;
        _isEdit = false;
        _dialogVisible = true;
    }

    private void OpenEditDialog(StudentDto student)
    {
        _editingStudent = new StudentDto
        {
            Id = student.Id,
            FirstName = student.FirstName,
            LastName = student.LastName,
            AccountNumber = student.AccountNumber,
            IdentificationNumber = student.IdentificationNumber,
            Gender = student.Gender,
            DateOfBirth = student.DateOfBirth,
            BirthPlace = student.BirthPlace,
            Address = student.Address,
            Handedness = student.Handedness,
            PhotoBase64 = student.PhotoBase64,
            MedicalConditions = student.MedicalConditions,
            HasAllergies = student.HasAllergies,
            AllergiesDescription = student.AllergiesDescription,
            HasSiblings = student.HasSiblings,
            SiblingsCount = student.SiblingsCount,
            SiblingsGrades = student.SiblingsGrades,
            ParentObservations = student.ParentObservations,
            ReferralEmails = student.ReferralEmails,
            IsActive = student.IsActive,
            Guardians = student.Guardians?.Select(g => new StudentGuardianDto
            {
                Id = g.Id,
                Type = g.Type,
                IdentificationNumber = g.IdentificationNumber,
                FullName = g.FullName,
                Phones = g.Phones,
                Email = g.Email
            }).ToList() ?? new List<StudentGuardianDto>()
        };

        // Ensure all 3 guardian types exist
        if (!_editingStudent.Guardians.Any(g => g.Type == GuardianType.Mother))
            _editingStudent.Guardians.Add(new StudentGuardianDto { Type = GuardianType.Mother });
        if (!_editingStudent.Guardians.Any(g => g.Type == GuardianType.Father))
            _editingStudent.Guardians.Add(new StudentGuardianDto { Type = GuardianType.Father });
        if (!_editingStudent.Guardians.Any(g => g.Type == GuardianType.Guardian))
            _editingStudent.Guardians.Add(new StudentGuardianDto { Type = GuardianType.Guardian });

        _birthDate = student.DateOfBirth;
        _isEdit = true;
        _dialogVisible = true;
    }

    private StudentGuardianDto GetGuardian(GuardianType type)
    {
        return _editingStudent.Guardians.First(g => g.Type == type);
    }

    private async Task SaveStudent()
    {
        _saving = true;
        try
        {
            if (_birthDate.HasValue) _editingStudent.DateOfBirth = _birthDate.Value;
            if (_isEdit) await ApiService.PutAsync($"students/{_editingStudent.Id}", _editingStudent);
            else await ApiService.PostAsync<StudentDto>("students", _editingStudent);
            Snackbar.Add(_isEdit ? "Estudiante actualizado" : "Estudiante creado", Severity.Success);
            _dialogVisible = false;
            await LoadStudents();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeleteStudent(StudentDto student)
    {
        bool? result = await DialogService.ShowMessageBoxAsync("Confirmar",
            $"Desea desactivar al estudiante {student.FullName}?", yesText: "Si", cancelText: "No");
        if (result == true)
        {
            try
            {
                await ApiService.DeleteAsync($"students/{student.Id}");
                Snackbar.Add("Estudiante desactivado", Severity.Warning);
                await LoadStudents();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }
}
